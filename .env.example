# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Database (Postgres on Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Magic-link auth — HMAC secret (32+ random bytes)
AUTH_HMAC_SECRET=

# Resend (transactional email — magic links, listing confirmations)
RESEND_API_KEY=

# Etsy Developer app credentials (Heye Lab Hub app — shared across tenants)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# Per-tenant Etsy OAuth tokens (set after the operator OAuth-connects their shop)
# These live in the database, NOT env vars. Listed here as a reminder of the schema.
