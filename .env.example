# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Database (Postgres on Neon — auto-wired by Vercel Storage integration)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Magic-link auth — HMAC secret (32+ random bytes)
# Generate with: openssl rand -hex 32
AUTH_HMAC_SECRET=

# Operator allowlist — comma-separated emails authorized to sign in
# Phase 1 example: collie.breah@gmail.com,winston@sageem.co
OPERATOR_EMAILS=

# Resend — transactional email (magic links, listing confirmations)
RESEND_API_KEY=
# Verified sender — format: "Display Name <hub@yourdomain.com>"
RESEND_FROM_EMAIL=

# Etsy Developer app credentials (Collie's per-tenant app — pending approval)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# Per-shop Etsy OAuth tokens (set after operator OAuth-connects their shop)
# These live in the database, NOT env vars. Listed here as a schema reminder.
