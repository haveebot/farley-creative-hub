# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Database (Postgres on Neon — auto-wired by Vercel Storage integration)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Session HMAC secret (32+ random bytes)
# Generate with: openssl rand -hex 32
AUTH_HMAC_SECRET=

# Signup gate — anyone with this key can create an account.
# Generate with: openssl rand -hex 16
SIGNUP_KEY=

# Resend — transactional email (NOT used for auth; used later for listing
# confirmations + customer-message digests)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Etsy Developer app credentials (Collie's per-tenant app — pending approval)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# Per-shop Etsy OAuth tokens are stored in the database, not env vars.
